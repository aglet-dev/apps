{
  "id": "profile",
  "name": {
    "default": "Profile",
    "zh": "个人资料",
    "ja": "プロフィール"
  },
  "description": {
    "default": "Profile manager — dogfood for DatePicker / Slider / RadioGroup / Image / Modal confirm.",
    "zh": "个人资料管理：含日期 / 滑块 / 单选 / 图片 / 确认弹窗。"
  },
  "version": "1.0.0",
  "runtime": "auto",
  "author": "agent-rt",
  "category": "other",
  "keywords": [
    "profile",
    "form",
    "showcase"
  ],
  "icon": "https://api.iconify.design/ph/user-circle-fill.svg?color=%233a6ea5&width=256",
  "permissions": [
    "data:read",
    "data:write"
  ],
  "window": {
    "style": "desktop",
    "width": 720,
    "height": 720
  },
  "collections": {
    "profiles": {
      "schema": {
        "name": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "birthday": {
          "type": "string"
        },
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "auto"
          ]
        },
        "volume": {
          "type": "number"
        },
        "bio": {
          "type": "string"
        }
      },
      "indexes": [
        "theme"
      ]
    }
  }
}
