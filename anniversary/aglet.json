{
  "id": "anniversary",
  "name": { "default": "Anniversary", "zh": "纪念日" },
  "description": { "default": "Track anniversaries (birthdays, milestones) with a live countdown to the next occurrence." },
  "version": "0.1.0",
  "renderer": "web",
  "default_locale": "en",
  "category": "utilities",
  "permissions": ["data:read", "data:write"],
  "window": { "style": "phone", "width": 400, "height": 720 },
  "collections": {
    "events": {
      "schema": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "kind": { "type": "string" },
        "recurring": { "type": "boolean" },
        "created_at": { "type": "string" },
        "days_until": { "type": "number" },
        "next_at": { "type": "string" },
        "milestone": { "type": "string" },
        "age_label": { "type": "string" }
      },
      "indexes": ["days_until", "kind"]
    }
  }
}
