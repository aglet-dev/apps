{
  "id": "anniversary",
  "name": { "default": "Anniversary", "zh": "纪念日", "ja": "記念日" },
  "description": {
    "default": "Track anniversaries (birthdays, milestones) with a live countdown to the next occurrence.",
    "zh": "记录纪念日（生日、里程碑），实时倒数到下一次。",
    "ja": "記念日（誕生日・節目）を登録し、次の発生までをカウントダウン。"
  },
  "version": "0.1.0",
  "renderer": "web",
  "default_locale": "en",
  "category": "utilities",
  "permissions": ["data:read", "data:write"],
  "window": { "style": "phone", "width": 400, "height": 720 },
  "collections": {
    "events": {
      "schema": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "kind": { "type": "string" },
        "recurring": { "type": "boolean" },
        "created_at": { "type": "string" },
        "days_until": { "type": "number" },
        "sort_key": { "type": "number" },
        "days_big": { "type": "string" },
        "days_word": { "type": "string" },
        "next_at": { "type": "string" },
        "milestone": { "type": "string" },
        "age_label": { "type": "string" }
      },
      "indexes": ["sort_key", "days_until", "kind"]
    }
  }
}
