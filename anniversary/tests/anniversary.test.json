{
  "name": "anniversary — refresh 派生计算 (freeze now=2026-05-30)",
  "aglet": "..",
  "steps": [
    { "action": "data.create", "params": { "collection": "events", "data": { "title": "宝宝", "date": "2025-08-15", "kind": "birthday", "recurring": true } }, "expect": { "ok": true } },
    { "action": "data.create", "params": { "collection": "events", "data": { "title": "小明", "date": "1990-12-25", "kind": "birthday", "recurring": true } }, "expect": { "ok": true } },
    { "action": "data.create", "params": { "collection": "events", "data": { "title": "结婚", "date": "2020-06-05", "kind": "anniversary", "recurring": true } }, "expect": { "ok": true } },

    { "action": "scripts.call", "params": { "fn": "refresh", "fixture": { "now": 1780142400000 } }, "expect": { "ok": true, "data_eq": { "result": { "count": 3 } } } },

    { "action": "data.list", "params": { "collection": "events", "query": { "where": { "title": "结婚" } } },
      "expect": { "ok": true, "items_len": 1, "data_eq": { "items": [ { "data": { "days_until": 6, "milestone": "6 yr", "next_at": "6/5" } } ] } } },

    { "action": "data.list", "params": { "collection": "events", "query": { "where": { "title": "宝宝" } } },
      "expect": { "ok": true, "items_len": 1, "data_eq": { "items": [ { "data": { "days_until": 77, "milestone": "Turns 1", "age_label": "9 mo old" } } ] } } },

    { "action": "data.list", "params": { "collection": "events", "query": { "where": { "title": "小明" } } },
      "expect": { "ok": true, "items_len": 1, "data_eq": { "items": [ { "data": { "milestone": "Turns 36", "age_label": "" } } ] } } }
  ]
}
