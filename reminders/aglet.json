{
  "id": "reminders",
  "name": {
    "default": "Reminders",
    "zh": "提醒",
    "ja": "リマインダー"
  },
  "description": {
    "default": "Lightweight reminders with optional due time. Background scan fires system notifications when due.",
    "zh": "轻量提醒，可选截止时间。后台扫描到点系统通知。",
    "ja": "軽量リマインダー、任意で締切時刻。バックグラウンドが到来時にシステム通知。"
  },
  "version": "1.0.0",
  "runtime": "auto",
  "author": "agent-rt",
  "category": "productivity",
  "keywords": [
    "reminders",
    "todo",
    "tasks",
    "notify"
  ],
  "icon": "https://api.iconify.design/ph/bell-fill.svg?color=%23ef6f5f&width=256",
  "screenshots": [
    {
      "url": "screenshots/01.png",
      "caption": "Active reminders list"
    }
  ],
  "permissions": [
    "data:read",
    "data:write",
    "notifications:post"
  ],
  "window": {
    "style": "phone",
    "width": 380,
    "height": 640
  },
  "jobs": [
    {
      "id": "due_scan",
      "trigger": {
        "kind": "interval",
        "ms": 60000
      },
      "while": "always",
      "handler": "dueScan"
    }
  ],
  "collections": {
    "items": {
      "schema": {
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "due_at": {
          "type": "string"
        },
        "completed": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        },
        "completed_at": {
          "type": "string"
        },
        "notified_at": {
          "type": "string"
        }
      },
      "indexes": [
        "completed",
        "due_at",
        "completed_at"
      ]
    }
  }
}
