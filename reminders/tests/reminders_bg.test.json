{
  "name": "reminders.background.js fixture-table (P2 bg.simulate)",
  "aglet": "..",
  "_comment": "测 reminders.background.js notify-once 逻辑。fixture 注 items collection；bg.simulate 跑 background.js capture aglet.bridge 调用列表。",
  "steps": [
    {
      "_comment": "overdue + 未通知过 → 必须 notify 一次 + 写 notified_at",
      "action": "bg.simulate",
      "params": {
        "fixture": {
          "collections": {
            "items": [
              {
                "data": {
                  "title": "Pay bills",
                  "due_at": "2020-01-01 00:00",
                  "completed": false
                }
              }
            ]
          }
        }
      },
      "expect": {
        "ok": true,
        "data": {
          "result": {
            "notified": 1,
            "skipped": 0
          },
          "captured_actions": [
            "data.list",
            "app.notify",
            "data.update"
          ]
        }
      }
    },
    {
      "_comment": "未来 due —— 一次都不通知",
      "action": "bg.simulate",
      "params": {
        "fixture": {
          "collections": {
            "items": [
              {
                "data": {
                  "title": "Future task",
                  "due_at": "2099-01-01 00:00",
                  "completed": false
                }
              }
            ]
          }
        }
      },
      "expect": {
        "ok": true,
        "data": {
          "result": {
            "notified": 0,
            "skipped": 1
          },
          "captured_actions": [
            "data.list"
          ]
        }
      }
    },
    {
      "_comment": "已 completed 的项 —— 即使 overdue 也不通知",
      "action": "bg.simulate",
      "params": {
        "fixture": {
          "collections": {
            "items": [
              {
                "data": {
                  "title": "Done task",
                  "due_at": "2020-01-01 00:00",
                  "completed": true
                }
              }
            ]
          }
        }
      },
      "expect": {
        "ok": true,
        "data": {
          "result": {
            "notified": 0
          },
          "captured_actions": [
            "data.list"
          ]
        }
      }
    },
    {
      "_comment": "已 notified_at 与 due_at 之后 —— 重复跑不再通知",
      "action": "bg.simulate",
      "params": {
        "fixture": {
          "collections": {
            "items": [
              {
                "data": {
                  "title": "Already notified",
                  "due_at": "2020-01-01 00:00",
                  "completed": false,
                  "notified_at": "2020-01-02 00:00"
                }
              }
            ]
          }
        }
      },
      "expect": {
        "ok": true,
        "data": {
          "result": {
            "notified": 0,
            "skipped": 1
          },
          "captured_actions": [
            "data.list"
          ]
        }
      }
    }
  ]
}
