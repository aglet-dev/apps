{
  "manifest": {
    "id": "timer",
    "name": { "default": "Timer", "zh": "计时器", "ja": "タイマー" },
    "description": {
      "default": "Simple countdown timer. Pick a preset, hit start, get notified when zero.",
      "zh": "简洁倒计时。选预设、按开始、归零通知。",
      "ja": "シンプルなカウントダウン。プリセットを選び、開始、ゼロで通知。"
    },
    "version": "1.0.0",
    "runtime": "json-ui-react",
    "permissions": [],
    "author": "agent-rt",
    "category": "utilities",
    "keywords": ["timer", "countdown", "stopwatch"],
    "window": { "style": "phone", "width": 320, "height": 480 },
    "state": {
      "seconds": 60,
      "remaining": 60,
      "running": false
    },
    "keys": {
      "Enter":  "toggle",
      " ":      "toggle",
      "Escape": "reset"
    }
  },
  "ui": "timer.ui.tsx"
}
