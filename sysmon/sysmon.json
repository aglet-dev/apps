{
  "manifest": {
    "id": "sysmon",
    "name": "System Monitor",
    "description": "OS CPU / memory dogfood for C1 memory storage + C2 sysinfo plugin + C7 declarative jobs",
    "version": "0.1.0",
    "runtime": "web",
    "requires": [
      {
        "plugin": "sysinfo",
        "version": ">=1.0"
      }
    ],
    "permissions": [
      "system:read",
      "data:read",
      "data:write"
    ],
    "collections": {
      "metrics": {
        "storage": "memory",
        "schema": {
          "ts": {
            "type": "integer"
          },
          "cpu_pct": {
            "type": "number"
          },
          "mem_used": {
            "type": "integer"
          },
          "mem_total": {
            "type": "integer"
          }
        }
      },
      "events": {
        "storage": "memory",
        "schema": {
          "ts": {
            "type": "integer"
          },
          "event": {
            "type": "string"
          }
        }
      }
    },
    "jobs": [
      {
        "id": "collect",
        "trigger": { "kind": "interval", "ms": 1000 },
        "while": "window_open",
        "handler": "collectMetrics"
      },
      {
        "id": "on_cpu_tick",
        "trigger": { "kind": "event", "event": "sysinfo.cpu_sampled" },
        "while": "window_open",
        "handler": "onCpuSampled"
      }
    ],
    "window": {
      "width": 360,
      "height": 280
    }
  },
  "ui": "sysmon.ui.tsx",
  "scripts": "sysmon.scripts.js"
}