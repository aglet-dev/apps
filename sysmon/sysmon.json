{
  "manifest": {
    "id": "sysmon",
    "name": "System Monitor",
    "description": "OS CPU / memory / disk dogfood. Subscribes to the `sysmon` stdio plugin's `cpu` resource — plugin pushes a sample every 1s, the host fans it out to `onCpuSample` via the plugin event bus. No polling.",
    "version": "0.3.0",
    "runtime": "web",
    "requires": [
      {
        "plugin": "sysmon",
        "version": ">=0.2"
      }
    ],
    "permissions": [
      "system:read",
      "data:read",
      "data:write"
    ],
    "collections": {
      "metrics": {
        "storage": "memory",
        "schema": {
          "ts": {
            "type": "integer"
          },
          "cpu_pct": {
            "type": "number"
          },
          "mem_used": {
            "type": "integer"
          },
          "mem_total": {
            "type": "integer"
          }
        }
      }
    },
    "jobs": [
      {
        "id": "on_cpu",
        "trigger": { "kind": "event", "event": "sysmon.cpu" },
        "while": "always",
        "handler": "onCpuSample"
      }
    ],
    "window": {
      "width": 360,
      "height": 280
    }
  },
  "ui": "sysmon.ui.tsx",
  "scripts": "sysmon.scripts.js"
}
