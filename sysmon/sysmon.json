{
  "manifest": {
    "id": "sysmon",
    "name": "System Monitor",
    "description": "OS CPU / memory / disk dogfood. Pulls host metrics from the `sysmon` stdio plugin (long-lived zig subprocess; macOS Mach API) at 1Hz and shows them in the menubar + a compact popover.",
    "version": "0.2.0",
    "runtime": "web",
    "requires": [
      {
        "plugin": "sysmon",
        "version": ">=0.1"
      }
    ],
    "permissions": [
      "system:read",
      "data:read",
      "data:write"
    ],
    "collections": {
      "metrics": {
        "storage": "memory",
        "schema": {
          "ts": {
            "type": "integer"
          },
          "cpu_pct": {
            "type": "number"
          },
          "mem_used": {
            "type": "integer"
          },
          "mem_total": {
            "type": "integer"
          }
        }
      }
    },
    "jobs": [
      {
        "id": "collect",
        "trigger": { "kind": "interval", "ms": 1000 },
        "while": "window_open",
        "handler": "collectMetrics"
      }
    ],
    "window": {
      "width": 360,
      "height": 280
    }
  },
  "ui": "sysmon.ui.tsx",
  "scripts": "sysmon.scripts.js"
}