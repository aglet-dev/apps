{
  "id": "sysmon",
  "name": {
    "default": "System Monitor",
    "zh": "系统监控",
    "ja": "システムモニター"
  },
  "description": {
    "default": "Menu-bar system monitor — CPU, memory, disk, GPU, battery, temperature, fan, network.",
    "zh": "菜单栏系统监控：CPU、内存、磁盘、GPU、电池、温度、风扇、网络。",
    "ja": "メニューバーのシステムモニター：CPU・メモリ・ディスク・GPU・バッテリー・温度・ファン・ネットワーク。"
  },
  "version": "0.5.0",
  "renderer": "web",
  "requires": [
    {
      "plugin": "sysmon",
      "version": ">=0.5"
    }
  ],
  "permissions": [
    "system:read",
    "data:read",
    "data:write"
  ],
  "collections": {
    "metrics": {
      "storage": "memory",
      "schema": {
        "ts": {
          "type": "integer"
        },
        "cpu_pct": {
          "type": "number"
        },
        "mem_used": {
          "type": "integer"
        },
        "mem_total": {
          "type": "integer"
        },
        "disk_pct": {
          "type": "number"
        },
        "gpu_pct": {
          "type": "number"
        },
        "temp_c": {
          "type": "number"
        },
        "rx_kbps": {
          "type": "number"
        },
        "tx_kbps": {
          "type": "number"
        }
      }
    }
  },
  "jobs": [
    {
      "id": "on_cpu",
      "trigger": {
        "kind": "event",
        "event": "sysmon.cpu"
      },
      "while": "always",
      "handler": "onCpuSample"
    }
  ],
  "window": {
    "width": 360,
    "height": 460
  }
}
