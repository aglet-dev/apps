{
  "id": "sysmon",
  "name": "System Monitor",
  "description": "System monitor — CPU, memory, disk, GPU, battery, temperature, fan, network. Subscribes to the `sysmon` stdio plugin's `cpu` resource — plugin pushes a sample every 1s, the host fans it out to `onCpuSample` via the plugin event bus. No polling.",
  "version": "0.5.0",
  "renderer": "web",
  "requires": [
    {
      "plugin": "sysmon",
      "version": ">=0.5"
    }
  ],
  "permissions": [
    "system:read",
    "data:read",
    "data:write"
  ],
  "collections": {
    "metrics": {
      "storage": "memory",
      "schema": {
        "ts": {
          "type": "integer"
        },
        "cpu_pct": {
          "type": "number"
        },
        "mem_used": {
          "type": "integer"
        },
        "mem_total": {
          "type": "integer"
        },
        "disk_pct": {
          "type": "number"
        },
        "gpu_pct": {
          "type": "number"
        },
        "temp_c": {
          "type": "number"
        },
        "rx_kbps": {
          "type": "number"
        },
        "tx_kbps": {
          "type": "number"
        }
      }
    }
  },
  "jobs": [
    {
      "id": "on_cpu",
      "trigger": {
        "kind": "event",
        "event": "sysmon.cpu"
      },
      "while": "always",
      "handler": "onCpuSample"
    }
  ],
  "window": {
    "width": 360,
    "height": 460
  }
}
