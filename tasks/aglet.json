          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "due_at": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "completed_at": {
          "type": "string"
        }
      },
      "indexes": [
        "status",
        "priority",
        "project",
        "due_at"
      ]
    }
  }
}
