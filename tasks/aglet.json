  },
  "description": {
    "default": "Lightweight task manager with priority, project and status tabs.",
    "zh": "轻量任务管理：优先级 / 项目 / 状态分类。",
    "ja": "軽量タスク管理。優先度・プロジェクト・状態タブ。"
  },
  "version": "1.0.0",
  "runtime": "auto",
  "author": "agent-rt",
  "category": "productivity",
  "keywords": [
    "tasks",
    "todo",
    "kanban",
    "productivity"
  ],
  "icon": "https://api.iconify.design/ph/list-checks-fill.svg?color=%233a6ea5&width=256",
  "permissions": [
    "data:read",
    "data:write"
  ],
  "window": {
    "style": "phone",
    "width": 420,
    "height": 720
