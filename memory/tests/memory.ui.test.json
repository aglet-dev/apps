{
  "name": "memory render + Menu pin E2E",
  "aglet": "..",
  "_comment": "seed unpinned memory → render in 所有记忆 section → snapshot",
  "steps": [
    {
      "action": "data.create",
      "params": {
        "collection": "memories",
        "data": {
          "text": "user prefers async iteration",
          "tags": "workflow,async",
          "project": "aglet",
          "agent": "claude",
          "kind": "preference",
          "pinned": false,
          "created_at": "2026-05-16T00:00:00Z"
        }
      }
    },
    {
      "_comment": "等 record 在 DataList row 出现。按 record 数据字段 (text) 选 —— 跨 locale 稳定。",
      "action": "view.waitfor",
      "select": {
        "role": "text",
        "in_item": {
          "text": "user prefers async iteration"
        }
      },
      "timeout": 5000,
      "expect": {
        "ok": true,
        "data": {
          "found": true
        }
      }
    },
    {
      "action": "data.list",
      "params": {
        "collection": "memories",
        "query": {
          "where": {
            "pinned": true
          }
        }
      },
      "expect": {
        "ok": true,
        "items_len": 0
      }
    },
    {
      "action": "data.list",
      "params": {
        "collection": "memories",
        "query": {
          "where": {
            "pinned": false
          }
        }
      },
      "expect": {
        "ok": true,
        "items_len": 1
      }
    }
  ]
}
