{
  "id": "img-convert",
  "name": {
    "default": "Image Convert",
    "zh": "图片转换",
    "ja": "画像変換"
  },
  "description": {
    "default": "Paste an image to convert between PNG, JPEG, WebP, BMP.",
    "zh": "粘贴图片，在 PNG / JPEG / WebP / BMP 之间转换",
    "ja": "画像を貼り付けて PNG / JPEG / WebP / BMP に変換"
  },
  "version": "1.0.0",
  "runtime": "auto",
  "requires": [
    {
      "plugin": "image",
      "version": ">=1.0"
    },
    {
      "plugin": "clipboard",
      "version": ">=1.0"
    }
  ],
  "permissions": [
    "image:read",
    "image:convert",
    "clipboard:read",
    "clipboard:write"
  ],
  "author": "agent-rt",
  "category": "utilities",
  "keywords": [
    "image",
    "convert",
    "png",
    "jpeg",
    "webp"
  ],
  "icon": "https://api.iconify.design/ph/file-image-fill.svg?color=%233a6ea5&width=256",
  "window": {
    "style": "phone",
    "width": 380,
    "height": 720
  },
  "collections": {
    "scratch": {
      "schema": {
        "src_dataurl": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "quality": {
          "type": "integer"
        }
      }
    }
  },
  "scripts": null,
  "state": {
    "src_meta": "",
    "out_dataurl": "",
    "out_meta": "",
    "error": ""
  }
}
