{
  "id": "inbox",
  "name": {
    "default": "Inbox",
    "zh": "收件箱",
    "ja": "インボックス"
  },
  "description": {
    "default": "Quick capture + archive — mobile-style 2-tab notebook.",
    "zh": "快速捕捉灵感 / 待办 / 链接；归档分类。",
    "ja": "メモ・ToDo・リンクの即時キャプチャ。"
  },
  "version": "1.0.0",
  "runtime": "auto",
  "author": "agent-rt",
  "category": "productivity",
  "keywords": [
    "notes",
    "capture",
    "inbox",
    "todo"
  ],
  "icon": "https://api.iconify.design/ph/tray-fill.svg?color=%233a6ea5&width=256",
  "permissions": [
    "data:read",
    "data:write"
  ],
  "window": {
    "style": "phone",
    "width": 393,
    "height": 852
  },
  "collections": {
    "notes": {
      "schema": {
        "title": {
          "type": "string"
        },
        "tag": {
          "type": "string",
          "enum": [
            "idea",
            "todo",
            "link"
          ]
        },
        "archived": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        }
      },
      "indexes": [
        "archived",
        "tag",
        "created_at"
      ]
    }
  }
}
