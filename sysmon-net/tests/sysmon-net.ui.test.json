{
  "name": "sysmon-net smoke — Tray popover Down/Up 双向标签",
  "aglet": "..",
  "steps": [
    { "action": "view.waitfor",
      "select": { "role": "text", "props": { "content": "Down" } },
      "timeout": 3000,
      "expect": { "ok": true, "data": { "found": true } } },
    { "action": "view.waitfor",
      "select": { "role": "text", "props": { "content": "Up" } },
      "timeout": 3000,
      "expect": { "ok": true, "data": { "found": true } } }
  ]
}
