{
  "id": "todo",
  "name": {
    "default": "Todo",
    "zh": "待办",
    "ja": "ToDo"
  },
  "description": {
    "default": "A minimal todo list — add, complete, delete.",
    "zh": "极简待办清单：添加、完成、删除。",
    "ja": "シンプルな ToDo リスト：追加・完了・削除。"
  },
  "version": "0.1.0",
  "renderer": "web",
  "category": "productivity",
  "permissions": [
    "data:read",
    "data:write"
  ],
  "collections": {
    "todos": {
      "schema": {
        "title": {
          "type": "string"
        },
        "done": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        }
      },
      "indexes": [
        "done"
      ]
    }
  },
  "window": {
    "style": "phone",
    "width": 380,
    "height": 600
  }
}
