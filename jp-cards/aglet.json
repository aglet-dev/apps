{
  "id": "jp-cards",
  "name": {
    "default": "JP Cards",
    "zh": "日语卡片",
    "ja": "日本語カード"
  },
  "description": {
    "default": "Japanese vocabulary flashcards with SRS (Leitner-style level interval).",
    "zh": "日语单词卡，Leitner 间隔重复。",
    "ja": "日本語単語カード、Leitner 方式の間隔反復。"
  },
  "version": "1.0.0",
  "runtime": "auto",
  "author": "agent-rt",
  "category": "education",
  "keywords": [
    "japanese",
    "flashcards",
    "srs",
    "learning"
  ],
  "icon": "https://api.iconify.design/ph/cards-three-fill.svg?color=%231f883d&width=256",
  "permissions": [
    "data:read",
    "data:write"
  ],
  "window": {
    "style": "phone",
    "width": 420,
    "height": 720
  },
  "state": {
    "reveal": false
  },
  "collections": {
    "cards": {
      "schema": {
        "front": {
          "type": "string"
        },
        "reading": {
          "type": "string"
        },
        "back": {
          "type": "string"
        },
        "level": {
          "type": "integer"
        },
        "next_review": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      },
      "indexes": [
        "level",
        "next_review"
      ]
    }
  }
}
