{
  "id": "tokstat",
  "name": {
    "default": "AI Token Usage",
    "zh": "AI 用量",
    "ja": "AI トークン使用量"
  },
  "description": {
    "default": "Claude + Codex usage (session & weekly) in your menu bar, with progress bars and reset countdowns.",
    "zh": "在菜单栏查看 Claude + Codex 的用量（会话与每周），含进度条与重置倒计时。",
    "ja": "メニューバーで Claude + Codex の使用量（セッション・週）を進捗バーとリセットまでのカウントダウン付きで表示。"
  },
  "version": "0.1.1",
  "license": "MIT",
  "min_runtime": "0.1.2",
  "renderer": "auto",
  "requires": [
    {
      "plugin": "tokstat",
      "version": ">=0.1.0"
    }
  ],
  "permissions": [
    "data:read",
    "data:write",
    "settings:read",
    "settings:write"
  ],
  "settings": {
    "groups": [
      {
        "title": { "default": "Display", "zh": "显示", "ja": "表示" },
        "fields": [
          {
            "key": "show",
            "label": { "default": "Show", "zh": "显示", "ja": "表示" },
            "type": "select",
            "default": "both",
            "options": [
              { "value": "both", "label": "Claude + Codex" },
              { "value": "claude", "label": { "default": "Claude only", "zh": "仅 Claude", "ja": "Claude のみ" } },
              { "value": "codex", "label": { "default": "Codex only", "zh": "仅 Codex", "ja": "Codex のみ" } }
            ]
          }
        ]
      }
    ]
  },
  "collections": {
    "samples": {
      "storage": "persistent",
      "schema": {
        "ts": {
          "type": "integer"
        },
        "source": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "session_pct": {
          "type": "integer"
        },
        "weekly_pct": {
          "type": "integer"
        },
        "session_resets_ms": {
          "type": "integer"
        },
        "weekly_resets_ms": {
          "type": "integer"
        },
        "total_cost_usd": {
          "type": "number"
        }
      }
    },
    "current": {
      "storage": "persistent",
      "schema": {
        "source": {
          "type": "string"
        },
        "ts": {
          "type": "integer"
        },
        "ok": {
          "type": "boolean"
        },
        "err": {
          "type": "string"
        },
        "menu_text": {
          "type": "string"
        },
        "session_pct": {
          "type": "integer"
        },
        "session_pct_text": {
          "type": "string"
        },
        "session_color": {
          "type": "string"
        },
        "session_reset_text": {
          "type": "string"
        },
        "weekly_pct": {
          "type": "integer"
        },
        "weekly_pct_text": {
          "type": "string"
        },
        "weekly_color": {
          "type": "string"
        },
        "weekly_reset_text": {
          "type": "string"
        },
        "cost_text": {
          "type": "string"
        },
        "plan_text": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        },
        "credits_text": {
          "type": "string"
        }
      }
    }
  },
  "jobs": [
    {
      "id": "on_sample",
      "run": "onSample",
      "on": "tokstat.sample",
      "while": "always"
    }
  ],
  "comment_state": "DATA_FLOW.md：popover/menubar 当前值全部走 SQLite `current` collection（数据源→SQLite→UI），不用 setState 表征。state 只留显示过滤的正向布尔 show_claude/show_codex（默认 true=both；scripts.syncShowFlags 按 settings.show 刷）——popover 结构性隐藏整段需正向守卫。",
  "state": { "show_claude": true, "show_codex": true },
  "window": {
    "width": 280,
    "height": 320
  }
}
