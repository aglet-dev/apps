{
  "id": "tokstat",
  "name": "AI Token Usage",
  "description": "Claude + Codex session/weekly usage in your menu bar. Claude: PTY-spawns `claude /usage` per minute. Codex: reads ~/.codex/sessions rollout JSONL (no subprocess). Menubar shows two lines `CL <s>·<w>` and `CX <s>·<w>`; popover breaks each side out with progress bars + reset countdowns.",
  "version": "0.2.0",
  "runtime": "web",
  "requires": [
    {
      "plugin": "tokstat",
      "version": ">=0.2"
    }
  ],
  "permissions": [
    "data:read",
    "data:write"
  ],
  "collections": {
    "samples": {
      "storage": "persistent",
      "schema": {
        "ts": {
          "type": "integer"
        },
        "source": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "session_pct": {
          "type": "integer"
        },
        "weekly_pct": {
          "type": "integer"
        },
        "session_resets_ms": {
          "type": "integer"
        },
        "weekly_resets_ms": {
          "type": "integer"
        },
        "total_cost_usd": {
          "type": "number"
        }
      }
    },
    "current": {
      "storage": "memory",
      "schema": {
        "source": {
          "type": "string"
        },
        "ts": {
          "type": "integer"
        },
        "ok": {
          "type": "boolean"
        },
        "err": {
          "type": "string"
        },
        "menu_text": {
          "type": "string"
        },
        "session_pct": {
          "type": "integer"
        },
        "session_pct_text": {
          "type": "string"
        },
        "session_color": {
          "type": "string"
        },
        "session_reset_text": {
          "type": "string"
        },
        "weekly_pct": {
          "type": "integer"
        },
        "weekly_pct_text": {
          "type": "string"
        },
        "weekly_color": {
          "type": "string"
        },
        "weekly_reset_text": {
          "type": "string"
        },
        "cost_text": {
          "type": "string"
        },
        "plan_text": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        },
        "credits_text": {
          "type": "string"
        }
      }
    }
  },
  "jobs": [
    {
      "id": "on_sample",
      "trigger": {
        "kind": "event",
        "event": "tokstat.sample"
      },
      "while": "always",
      "handler": "onSample"
    }
  ],
  "comment_state": "DATA_FLOW.md：popover/menubar 当前值全部走 SQLite `current` collection（数据源→SQLite→UI），不再用 setState 表征。state 留空。",
  "state": {},
  "window": {
    "width": 280,
    "height": 320
  }
}
