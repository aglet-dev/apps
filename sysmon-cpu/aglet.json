{
  "id": "sysmon-cpu",
  "name": "CPU Monitor",
  "description": "menubar CPU usage live + 60s history sparkline",
  "version": "0.1.0",
  "runtime": "web",
  "requires": [
    {
      "plugin": "sysinfo",
      "version": ">=1.0"
    }
  ],
  "permissions": [
    "system:read",
    "data:read",
    "data:write"
  ],
  "collections": {
    "metrics": {
      "storage": "memory",
      "schema": {
        "ts": {
          "type": "integer"
        },
        "cpu_pct": {
          "type": "number"
        }
      }
    }
  },
  "jobs": [
    {
      "id": "collect",
      "trigger": {
        "kind": "interval",
        "ms": 1000
      },
      "while": "window_open",
      "handler": "collectCpu"
    }
  ],
  "window": {
    "width": 320,
    "height": 200
  }
}
